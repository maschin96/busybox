. ./testing.sh

# testing "description" "command" "result" "infile" "stdin"
optional FEATURE_CATV
testing 'cat -e' \
	'cat -e' \
	'foo$\n' \
	'' \
	'foo\n'
SKIP=

optional FEATURE_CATV
testing 'cat -v' \
	'cat -v' \
	'foo\n' \
	'' \
	'foo\n'
SKIP=

optional FEATURE_CATN
testing 'cat -n' \
	'cat -n' \
"\
     1	line 1
     2	
     3	line 3
" \
	'' \
	'line 1\n\nline 3\n'
SKIP=

optional FEATURE_CATN
testing 'cat -b' \
	'cat -b' \
"\
     1	line 1

     2	line 3
" \
	'' \
	'line 1\n\nline 3\n'
SKIP=


# Migrated from the former testsuite/cat/ directory.
testing_script "cat-prints-a-file" <<'BB_TEST_EOF_cat_1'
echo I WANT > foo
busybox cat foo >bar
cmp foo bar
BB_TEST_EOF_cat_1
testing_script "cat-prints-a-file-and-standard-input" <<'BB_TEST_EOF_cat_2'
echo I WANT > foo
echo SOMETHING | busybox cat foo - >bar
cat >baz <<EOF
I WANT
SOMETHING
EOF
cmp bar baz
BB_TEST_EOF_cat_2

exit $FAILCOUNT
