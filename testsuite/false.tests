. ./testing.sh

# Migrated from the former testsuite/false/ directory.
testing_script "false-is-silent" <<'BB_TEST_EOF_false_1'
busybox false 2>&1 | cmp - /dev/null
BB_TEST_EOF_false_1
testing_script "false-returns-failure" <<'BB_TEST_EOF_false_2'
! busybox false
BB_TEST_EOF_false_2

exit $FAILCOUNT
