#!/bin/sh
# Licensed under GPLv2, see file LICENSE in this source tree.

. ./testing.sh

# Migrated from the former testsuite/hostid/ directory.
testing_script "hostid-works" <<'BB_TEST_EOF_hostid_1'
h=x$(busybox hostid)
# Is $h a sequence of hex numbers?
case "$h" in
 x*[!0-9a-f]*) false;;
 *) true;;
esac
BB_TEST_EOF_hostid_1

exit $FAILCOUNT
