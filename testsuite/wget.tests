#!/bin/sh
# Licensed under GPLv2, see file LICENSE in this source tree.

. ./testing.sh

# Migrated from the former testsuite/wget/ directory.
testing_script "wget--O-overrides--P" <<'BB_TEST_EOF_wget_1'
test x"$SKIP_INTERNET_TESTS" != x"" && exit

mkdir foo
busybox wget -q -O index.html -P foo http://www.google.com/
test -s index.html
BB_TEST_EOF_wget_1
testing_script "wget-handles-empty-path" <<'BB_TEST_EOF_wget_2'
test x"$SKIP_INTERNET_TESTS" != x"" && exit

busybox wget http://www.google.com
BB_TEST_EOF_wget_2
testing_script "wget-retrieves-google-index" <<'BB_TEST_EOF_wget_3'
test x"$SKIP_INTERNET_TESTS" != x"" && exit

busybox wget -q -O foo http://www.google.com/
test -s foo
BB_TEST_EOF_wget_3
testing_script "wget-supports--P" <<'BB_TEST_EOF_wget_4'
test x"$SKIP_INTERNET_TESTS" != x"" && exit

mkdir foo
busybox wget -q -P foo http://www.google.com/
test -s foo/index.html
BB_TEST_EOF_wget_4

exit $FAILCOUNT
