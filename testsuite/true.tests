. ./testing.sh

# Migrated from the former testsuite/true/ directory.
testing_script "true-is-silent" <<'BB_TEST_EOF_true_1'
busybox true 2>&1 | cmp - /dev/null
BB_TEST_EOF_true_1
testing_script "true-returns-success" <<'BB_TEST_EOF_true_2'
busybox true
BB_TEST_EOF_true_2

exit $FAILCOUNT
