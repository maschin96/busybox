#!/bin/sh
# Licensed under GPLv2, see file LICENSE in this source tree.

. ./testing.sh

# Migrated from the former testsuite/echo/ directory.
optional FEATURE_FANCY_ECHO
testing_script "echo-does-not-print-newline" <<'BB_TEST_EOF_echo_1'
# FEATURE: CONFIG_FEATURE_FANCY_ECHO

test `busybox echo -n word | wc -c` -eq 4
BB_TEST_EOF_echo_1
SKIP=
testing_script "echo-prints-argument" <<'BB_TEST_EOF_echo_2'
test xfubar = x`busybox echo fubar`
BB_TEST_EOF_echo_2
testing_script "echo-prints-arguments" <<'BB_TEST_EOF_echo_3'
test "`busybox echo foo bar`" = "foo bar"
BB_TEST_EOF_echo_3
optional DESKTOP
testing_script "echo-prints-dash" <<'BB_TEST_EOF_echo_4'
# FEATURE: CONFIG_DESKTOP
test "`busybox echo - | od -t x1 | head -n 1`" = "0000000 2d 0a"
BB_TEST_EOF_echo_4
SKIP=
testing_script "echo-prints-newline" <<'BB_TEST_EOF_echo_5'
test `busybox echo word | wc -c` -eq 5
BB_TEST_EOF_echo_5
optional DESKTOP
testing_script "echo-prints-non-opts" <<'BB_TEST_EOF_echo_6'
# FEATURE: CONFIG_DESKTOP
test "`busybox echo -neEZ | od -t x1 | head -n 1`" = "0000000 2d 6e 65 45 5a 0a"
BB_TEST_EOF_echo_6
SKIP=
optional FEATURE_FANCY_ECHO DESKTOP
testing_script "echo-prints-slash-zero" <<'BB_TEST_EOF_echo_7'
# FEATURE: CONFIG_FEATURE_FANCY_ECHO CONFIG_DESKTOP

test "`busybox echo -e -n 'msg\n\0' | od -t x1 | head -n 1`" = "0000000 6d 73 67 0a 00"
BB_TEST_EOF_echo_7
SKIP=
optional FEATURE_FANCY_ECHO DESKTOP
testing_script "echo-prints-slash_00041" <<'BB_TEST_EOF_echo_8'
# FEATURE: CONFIG_FEATURE_FANCY_ECHO CONFIG_DESKTOP

test "`busybox echo -ne '\00041z' | od -t x1 | head -n 1`" = "0000000 04 31 7a"
BB_TEST_EOF_echo_8
SKIP=
optional FEATURE_FANCY_ECHO DESKTOP
testing_script "echo-prints-slash_0041" <<'BB_TEST_EOF_echo_9'
# FEATURE: CONFIG_FEATURE_FANCY_ECHO CONFIG_DESKTOP

test "`busybox echo -ne '\0041z' | od -t x1 | head -n 1`" = "0000000 21 7a"
BB_TEST_EOF_echo_9
SKIP=
optional FEATURE_FANCY_ECHO DESKTOP
testing_script "echo-prints-slash_041" <<'BB_TEST_EOF_echo_10'
# FEATURE: CONFIG_FEATURE_FANCY_ECHO CONFIG_DESKTOP

test "`busybox echo -ne '\041z' | od -t x1 | head -n 1`" = "0000000 21 7a"
BB_TEST_EOF_echo_10
SKIP=
optional FEATURE_FANCY_ECHO DESKTOP
testing_script "echo-prints-slash_41" <<'BB_TEST_EOF_echo_11'
# FEATURE: CONFIG_FEATURE_FANCY_ECHO CONFIG_DESKTOP

test "`busybox echo -ne '\41z' | od -t x1 | head -n 1`" = "0000000 21 7a"
BB_TEST_EOF_echo_11
SKIP=

exit $FAILCOUNT
